<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade">
    <name>Clinic Chatbot</name>
    <version>0.1.0</version>
    <author>Mads Freitag</author>
    <description>Reusable chatbot module for dental clinics</description>

    <namespace path="src">Mads\Module\ClinicChatbot</namespace>

    <files>
        <folder module="mod_clinic_chatbot">services</folder>
        <folder>src</folder>
        <folder>media</folder>
    </files>

    <config>
        <fields name="params">
            <fieldset name="basic" label="Klinikoplysninger">
                <field
                    name="clinic_id"
                    type="text"
                    label="Clinic ID"
                    description="Unikt klient-id til backend, f.eks. videsignersmil eller fortanden"
                    required="true"
                    filter="cmd"
                    default=""
                />
                <field
                    name="clinic_name"
                    type="text"
                    label="Kliniknavn"
                    required="true"
                    filter="string"
                    default=""
                />
                <field
                    name="clinic_phone"
                    type="text"
                    label="Telefonnummer"
                    required="true"
                    filter="string"
                    default=""
                />
                <field
                    name="clinic_address"
                    type="text"
                    label="Adresse"
                    required="true"
                    filter="string"
                    default=""
                />
                <field
                    name="booking_url"
                    type="url"
                    label="Booking URL"
                    required="true"
                    default=""
                />
                <field
                    name="welcome_message"
                    type="textarea"
                    label="Velkomstbesked"
                    rows="4"
                    required="true"
                    filter="string"
                    default="Hej og velkommen. Jeg kan hjælpe med spørgsmål om klinikken, behandlinger og generelle tandspørgsmål."
                />
            </fieldset>

            <fieldset name="knowledge" label="Klinikviden">
                <field
                    name="clinic_knowledge"
                    type="textarea"
                    label="Klinikbeskrivelse og behandlinger"
                    description="Beskriv klinikken, behandlingstyper, særlige oplysninger og praktiske retningslinjer."
                    rows="12"
                    filter="raw"
                    default=""
                />
            </fieldset>
        </fields>
    </config>
</extension>